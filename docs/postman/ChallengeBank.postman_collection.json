{
  "info": {
    "_postman_id": "challengebank-api-v2",
    "name": "ChallengeBank API",
    "description": "API unificada — envelope: `{ Status, Message, Trace, Data? }` (mensagens em português).\n\n**Auth:** Login (admin) primeiro → `Data.accessToken` no header Bearer.\n\n**Credenciais:** admin/Admin@123 | user/User@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "clientId", "value": "" },
    { "key": "clientId2", "value": "" },
    { "key": "transferId", "value": "" }
  ],
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Login (admin)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "if (pm.response.code === 200) {",
                "  const token = pm.response.json().Data.accessToken;",
                "  pm.collectionVariables.set('accessToken', token);",
                "  pm.environment.set('accessToken', token);",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login (user)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const token = pm.response.json().Data.accessToken;",
                "  pm.collectionVariables.set('accessToken', token);",
                "  pm.environment.set('accessToken', token);",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user\",\n  \"password\": \"User@123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Create Client (com bankingDetails)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('clientId', pm.response.json().Data.id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Maria Silva Santos\",\n  \"documentNumber\": \"12345678901\",\n  \"email\": \"maria.silva@challengebank.com\",\n  \"address\": {\n    \"street\": \"Rua das Flores, 100\",\n    \"city\": \"São Paulo\",\n    \"state\": \"SP\",\n    \"postalCode\": \"01310-100\"\n  },\n  \"bankingDetails\": {\n    \"agency\": \"0001\",\n    \"accountNumber\": \"12345-6\"\n  }\n}"
            },
            "url": "{{baseUrl}}/api/clients"
          }
        },
        {
          "name": "Create Client 2 (destinatário)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('clientId2', pm.response.json().Data.id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"João Pedro Oliveira\",\n  \"documentNumber\": \"98765432100\",\n  \"email\": \"joao.oliveira@challengebank.com\",\n  \"bankingDetails\": {\n    \"agency\": \"0002\",\n    \"accountNumber\": \"98765-4\"\n  }\n}"
            },
            "url": "{{baseUrl}}/api/clients"
          }
        },
        {
          "name": "Get Client by Id",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json().Data;",
                  "pm.test('tem bankingDetails', () => pm.expect(b).to.have.property('bankingDetails'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/clients/{{clientId}}"
          }
        },
        {
          "name": "Patch Client (parcial) — Admin",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Execute Login (admin) antes — PATCH exige role Admin.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 403) {",
                  "  console.warn('403: use Login (admin), não Login (user). Refaça o login e tente de novo.');",
                  "}",
                  "pm.test('200 OK (admin)', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Maria Silva Atualizada\",\n  \"bankingDetails\": {\n    \"agency\": \"0001\",\n    \"accountNumber\": \"99999-9\"\n  }\n}"
            },
            "url": "{{baseUrl}}/api/clients/{{clientId}}"
          }
        },
        {
          "name": "Get Client - Not Found",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/clients/00000000-0000-0000-0000-000000000000"
          }
        }
      ]
    },
    {
      "name": "Transferências",
      "item": [
        {
          "name": "Create Transfer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('transferId', pm.response.json().Data.id);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderUserId\": \"{{clientId}}\",\n  \"receiverUserId\": \"{{clientId2}}\",\n  \"amount\": 1500.75,\n  \"description\": \"Pagamento de serviços\"\n}"
            },
            "url": "{{baseUrl}}/api/transfers"
          }
        },
        {
          "name": "Get Transfer by Id",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status Completed', () => pm.expect(pm.response.json().Data.status).to.eql(2));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/transfers/{{transferId}}"
          }
        },
        {
          "name": "List Transfers by User — Admin",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/transfers/user/{{clientId}}"
          }
        },
        {
          "name": "Create Transfer - mesmo usuário (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderUserId\": \"{{clientId}}\",\n  \"receiverUserId\": \"{{clientId}}\",\n  \"amount\": 100,\n  \"description\": \"Inválido\"\n}"
            },
            "url": "{{baseUrl}}/api/transfers"
          }
        },
        {
          "name": "Get Transfer - Not Found",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/transfers/00000000-0000-0000-0000-000000000000"
          }
        }
      ]
    },
    {
      "name": "Fluxo completo (Runner)",
      "item": [
        {
          "name": "0. Login Admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const token = pm.response.json().Data.accessToken;",
                "  pm.collectionVariables.set('accessToken', token);",
                "  pm.environment.set('accessToken', token);",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
