@ChallengeBank.API_HostAddress = http://localhost:5000
@token = 

### Login Admin
# @name login
POST {{ChallengeBank.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "Admin@123"
}

###
@token = {{login.response.body.accessToken}}

### Health (sem token)
GET {{ChallengeBank.API_HostAddress}}/health

### Clientes
POST {{ChallengeBank.API_HostAddress}}/api/clients
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fullName": "Maria Silva",
  "documentNumber": "12345678901",
  "email": "maria@email.com",
  "bankingDetails": { "agency": "0001", "accountNumber": "12345-6" }
}

###
GET {{ChallengeBank.API_HostAddress}}/api/clients/{{clientId}}
Authorization: Bearer {{token}}

###
PATCH {{ChallengeBank.API_HostAddress}}/api/clients/{{clientId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Maria Silva Atualizada"
}

### Transferências
POST {{ChallengeBank.API_HostAddress}}/api/transfers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "senderUserId": "{{clientId}}",
  "receiverUserId": "{{clientId2}}",
  "amount": 100.50,
  "description": "Teste"
}

###
GET {{ChallengeBank.API_HostAddress}}/api/transfers/{{transferId}}
Authorization: Bearer {{token}}

###
GET {{ChallengeBank.API_HostAddress}}/api/transfers/user/{{clientId}}
Authorization: Bearer {{token}}
