{
  "ConnectionStrings": {
    "ChallengeBankDb": "Server=(localdb)\\MSSQLLocalDB;Database=ChallengeBank;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true;Connect Timeout=15"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "KeyPrefix": "challengebank"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "Exchange": "challengebank.events",
    "RoutingKeyBankingDetailsUpdated": "clients.bankingdetails.updated"
  },
  "Jwt": {
    "Key": "ChallengeBank-Development-Secret-Key-Min-32-Chars!",
    "Issuer": "ChallengeBank",
    "Audience": "ChallengeBank",
    "ExpirationMinutes": 60
  },
  "Auth": {
    "Users": [
      { "Username": "user", "Password": "User@123", "Role": "User" },
      { "Username": "admin", "Password": "Admin@123", "Role": "Admin" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
